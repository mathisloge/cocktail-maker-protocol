<?xml version="1.0" encoding="UTF-8"?>
<schema name="proto" displayName="Cocktail Maker Serial Protocol" endian="little" version="0x010000"
    dslVersion="8">
    <description>
        Protocol used for serial communication between the Station and the Pods.

        Definition of the sender property:
        sender=server: Station
        sender=client: Pod

        Every server-initiated message is answered by the client with either a dedicated
        response message or a generic Ack, correlated via the frame's TransactionId.
    </description>

    <fields>
        <!-- General messages -->
        <string name="MsgPingName" defaultValue="Ping Server Message" />
        <string name="MsgPongName" defaultValue="Pong Client Message" />
        <string name="MsgAckName" defaultValue="Ack" />
        <string name="MsgNakName" defaultValue="Nak" />
        <string name="MsgDeviceInfoRequestName" defaultValue="Device Info Request" />
        <string name="MsgDeviceInfoResponseName" defaultValue="Device Info Response" />
        <string name="MsgEmergencyStopName" defaultValue="Emergency Stop" />
        <!-- Load cell related messages -->
        <string name="MsgLoadCellResetOffsetName" defaultValue="LoadCell Reset Offset" />
        <string name="MsgLoadCellSetRefWeightName" defaultValue="LoadCell Set Reference Weight" />
        <string name="MsgLoadCellTareName" defaultValue="LoadCell Tare" />
        <!-- Pump related messages -->
        <string name="MsgPumpStartCalibrationName" defaultValue="Pump Start Calibration" />
        <string name="MsgPumpFinishedCalibrationResponseName"
            defaultValue="Pump Finished Calibration Response" />
        <!-- Dispenser related messages -->
        <string name="MsgHighlightDispenserName" defaultValue="Highlight Dispenser" />
        <string name="MsgDispenseName" defaultValue="Dispense" />
        <string name="MsgDispenseFinishedName" defaultValue="Dispense Finished" />
        <string name="MsgDispenserFillingQuantityRequestName"
            defaultValue="Dispenser Filling Quantity Request" />
        <string name="MsgDispenserFillingQuantityResponseName"
            defaultValue="Dispenser Filling Quantity Response" />

        <enum name="MsgId" type="uint16" semanticType="messageId">
            <!-- General messages -->
            <validValue name="Ping" val="0x001" displayName="^MsgPingName" />
            <validValue name="Pong" val="0x002" displayName="^MsgPongName" />
            <validValue name="Ack" val="0x003" displayName="^MsgAckName" />
            <validValue name="Nak" val="0x004" displayName="^MsgNakName" />
            <validValue name="DeviceInfoRequest" val="0x010" displayName="^MsgDeviceInfoRequestName" />
            <validValue name="DeviceInfoResponse" val="0x011"
                displayName="^MsgDeviceInfoResponseName" />
            <validValue name="EmergencyStop" val="0x012" displayName="^MsgEmergencyStopName" />

            <!-- Load cell related messages -->
            <validValue name="LoadCellResetOffset" val="0x020"
                displayName="^MsgLoadCellResetOffsetName" />
            <validValue name="LoadCellSetRefWeight" val="0x021"
                displayName="^MsgLoadCellSetRefWeightName" />
            <validValue name="LoadCellTare" val="0x022"
                displayName="^MsgLoadCellTareName" />

            <!-- Pump related messages -->
            <validValue name="PumpStartCalibration" val="0x031"
                displayName="^MsgPumpStartCalibrationName" />
            <validValue name="PumpFinishedCalibrationResponse" val="0x032"
                displayName="^MsgPumpFinishedCalibrationResponseName" />

            <!-- Dispenser related messages -->
            <validValue name="HighlightDispenser" val="0x040"
                displayName="^MsgHighlightDispenserName" />
            <validValue name="Dispense" val="0x041" displayName="^MsgDispenseName" />
            <validValue name="DispenseFinished" val="0x042" displayName="^MsgDispenseFinishedName" />
            <validValue name="DispenserFillingQuantityRequest" val="0x043"
                displayName="^MsgDispenserFillingQuantityRequestName" />
            <validValue name="DispenserFillingQuantityResponse" val="0x044"
                displayName="^MsgDispenserFillingQuantityResponseName" />
        </enum>

        <enum name="ErrorCode" type="uint8">
            <validValue name="InvalidParameter" val="0" displayName="Invalid Parameter" />
            <validValue name="DispenserNotFound" val="1" displayName="Dispenser Not Found" />
            <validValue name="UnsupportedInCurrentState" val="2"
                displayName="Unsupported In Current State" />
            <validValue name="HardwareFault" val="3" displayName="Hardware Fault" />
            <validValue name="Busy" val="4" displayName="Busy" />
            <validValue name="NotCalibrated" val="5" displayName="Not Calibrated" />
            <validValue name="InternalError" val="6" displayName="Internal Error" />
        </enum>
        <int name="DispenserId" type="uint8" />
        <int name="Millilitre" type="int16" />
        <int name="Gram" type="int16" />
        <int name="PumpStep" type="uint16" />
        <int name="Milliseconds" type="int16" units="milliseconds" />

        <enum name="LedEffect" type="uint8">
            <validValue name="Off" val="0" />
            <validValue name="Highlight" val="1" />
            <validValue name="Warn" val="0x2" />
        </enum>
    </fields>

    <!-- General messages -->
    <message name="Ping"
        id="MsgId.Ping" sender="server" displayName="^MsgPingName">
        <description>
            Keep-alive message initiated by the server.
        </description>
    </message>
    <message
        name="Pong" id="MsgId.Pong" sender="client" displayName="^MsgPongName">
        <description>
            Keep-alive response sent by the client.
        </description>
    </message>
    <message
        name="Ack" id="MsgId.Ack" sender="client" displayName="^MsgAckName">
        <description>
            General acknowledgment message for a command.
            The command being acknowledged is identified via the frame's TransactionId.
        </description>
    </message>
    <message
        name="Nak" id="MsgId.Nak" sender="client" displayName="^MsgNakName">
        <description>
            General negative-acknowledgment message for a command.
            The command being acknowledged is identified via the frame's TransactionId.
        </description>
        <fields>
            <ref field="ErrorCode" description="Reason the command could not be executed." />
        </fields>
    </message>

    <message
        name="DeviceInfoRequest" id="MsgId.DeviceInfoRequest" sender="server"
        displayName="^MsgDeviceInfoRequestName">
        <description>
            Requests the device information.
            Will be responded by DeviceInfoResponse.
        </description>
    </message>
    <message
        name="DeviceInfoResponse" id="MsgId.DeviceInfoResponse" sender="client"
        displayName="^MsgDeviceInfoResponseName">
        <description>
            Response to a DeviceInfoRequest, containing the device information.
        </description>
        <fields>
            <int name="HardwareRevision" type="uint8" />
            <int name="FirmwareMajor" type="uint8" />
            <int name="FirmwareMinor" type="uint8" />
            <int name="FirmwarePatch" type="uint8" />
            <int name="NumPumps" type="uint8" />
            <int name="NumValves" type="uint8" />
            <string name="DeviceName">
                <lengthPrefix>
                    <int name="LengthPrefix" type="uint8" />
                </lengthPrefix>
            </string>
        </fields>
    </message>

    <message
        name="EmergencyStop" id="MsgId.EmergencyStop" sender="server"
        displayName="^MsgEmergencyStopName">
        <description>
            Requests the client to bring the machine into a safe state.
            The client must respond with an Ack/Nak.
        </description>
    </message>

    <!-- Load cell related messages -->
    <message
        name="LoadCellResetOffset" id="MsgId.LoadCellResetOffset" sender="server"
        displayName="^MsgLoadCellResetOffsetName">
        <description>
            Requests a specific load cell to be reset to its current measured value.
            The client must respond with an Ack/Nak.
        </description>
        <fields>
            <ref field="DispenserId"
                description="The dispenser whose load cell this command applies to." />
        </fields>
    </message>
    <message
        name="LoadCellSetRefWeight" id="MsgId.LoadCellSetRefWeight" sender="server"
        displayName="^MsgLoadCellSetRefWeightName">
        <description>
            Sets a specific load cell's current measurement to the given reference weight.
            The client must respond with an Ack/Nak.
        </description>
        <fields>
            <ref field="DispenserId"
                description="The dispenser whose load cell this command applies to." />
            <ref field="Gram" description="The reference weight which is currently applied." />
        </fields>
    </message>
    <message
        name="LoadCellTare" id="MsgId.LoadCellTare" sender="server"
        displayName="^MsgLoadCellTareName">
        <description>
            Uses the current applied weight as the zero point.
            The client must respond with an Ack/Nak.
        </description>
        <fields>
            <ref field="DispenserId"
                description="The dispenser whose load cell this command applies to." />
        </fields>
    </message>

    <!-- Pump related messages -->
    <message
        name="PumpStartCalibration" id="MsgId.PumpStartCalibration" sender="server"
        displayName="^MsgPumpStartCalibrationName">
        <description>
            Start the calibration of a pump.
            The client must respond with an Ack/Nak.
        </description>
        <fields>
            <ref field="DispenserId" />
            <ref field="PumpStep" description="The number of steps to take." />
        </fields>
    </message>
    <message
        name="PumpFinishedCalibrationResponse" id="MsgId.PumpFinishedCalibrationResponse"
        sender="client"
        displayName="^MsgPumpFinishedCalibrationResponseName">
        <description>
            Should be send after a calibration has finished.
            Must use same TransactionId as the PumpStartCalibration.
        </description>
        <fields>
            <ref field="PumpStep" description="Number of steps per millilitre" />
            <ref field="Millilitre" description="The pumped millilitre." />
        </fields>
    </message>

    <!-- Dispenser related messages -->
    <message
        name="HighlightDispenser" id="MsgId.HighlightDispenser" sender="server"
        displayName="^MsgHighlightDispenserName">
        <description>
            Highlight a dispenser.
            The client must respond with an Ack/Nak.
        </description>
        <fields>
            <ref field="DispenserId" />
            <ref field="LedEffect" />
            <ref field="Milliseconds" description="Time after the led effect will be turned off." />
        </fields>
    </message>

    <message name="Dispense" id="MsgId.Dispense" sender="server"
        displayName="^MsgDispenseName">
        <description>
            Dispense the specified amount of liquied.
            The client must respond with an Ack/Nak.
            After the client has finished, a DispenseFinished will be send, or a Nak in case of an
            error.
        </description>
        <fields>
            <ref field="DispenserId" />
            <ref field="Millilitre" description="The amount to dispense." />
        </fields>
    </message>

    <message name="DispenseFinished" id="MsgId.DispenseFinished" sender="client"
        displayName="^MsgDispenseFinishedName">
        <description>
            The dispense action has been finished.
        </description>
        <fields>
        </fields>
    </message>

    <message name="DispenserFillingQuantityRequest" id="MsgId.DispenserFillingQuantityRequest"
        sender="server"
        displayName="^MsgDispenserFillingQuantityRequestName">
        <description>
            Request the current filling quantity of a dispenser.
        </description>
        <fields>
            <ref field="DispenserId" />
        </fields>
    </message>

    <message name="DispenserFillingQuantityResponse" id="MsgId.DispenserFillingQuantityResponse"
        sender="client"
        displayName="^MsgDispenserFillingQuantityResponseName">
        <description>
            The response to DispenserFillingQuantityRequest.
            Reports the filling level of a dispenser.
        </description>
        <fields>
            <ref field="Millilitre" description="The measured remaining volume." />
        </fields>
    </message>

    <interface
        name="FrameInterface">
        <int name="TransactionId" type="uint8" />
    </interface>

    <frame name="Frame">
        <sync name="Sync">
            <int name="SyncField" type="uint16" defaultValue="0xabcd" />
        </sync>
        <size name="Size">
            <int name="SizeField" type="uint16" />
        </size>
        <id name="Id" field="MsgId" />
        <value name="TransactionId">
            <interfaceFieldName value="TransactionId" />
            <field>
                <int name="TransactionIdField" type="uint8" />
            </field>
        </value>
        <payload name="Data" />
        <checksum name="Checksum" alg="crc-16" from="Size">
            <int name="ChecksumField" type="uint16" />
        </checksum>
    </frame>
</schema>
